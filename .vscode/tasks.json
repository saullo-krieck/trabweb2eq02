{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ng serve",
            "type": "npm",
            "script": "start",
            "path": "frontend/",
            "isBackground": true,
            "problemMatcher": {
                "owner": "typescript",
                "pattern": "$tsc",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "Changes detected"
                    },
                    "endsPattern": {
                        "regexp": "bundle generation (complete|failed)"
                    }
                }
            }
        }
    ]
}